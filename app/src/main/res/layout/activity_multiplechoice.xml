<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_height="match_parent"
    android:layout_width="match_parent"
    android:background="@color/yellowbg"
    android:id="@+id/main">

    <FrameLayout
        android:layout_height="match_parent"
        android:layout_width="match_parent"
        android:id="@+id/number_container">

    </FrameLayout>

    <LinearLayout
        android:layout_height="match_parent"
        android:layout_width="match_parent"
        android:gravity="center">

        <TextView
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:textSize="33sp"
            android:textColor="#FFFFFF"
            android:textAlignment="center"
            app:layout_constraintTop_toTopOf="parent"
            android:shadowRadius="2"
            app:layout_constraintStart_toStartOf="parent"
            android:fontFamily="@font/paytone_one"
            android:shadowColor="#000000"
            app:layout_constraintEnd_toEndOf="parent"
            android:shadowDx="4"
            android:shadowDy="3"
            android:id="@+id/operationDisplay"
            android:text="Multiplication" />

    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_height="match_parent"
        android:layout_width="match_parent"
        android:id="@+id/gameView">

        <TextView
            android:id="@+id/Border"
            android:layout_width="308dp"
            android:layout_height="250dp"
            android:background="@drawable/bg_blackboard"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.496"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/linearLayout2" />

        <LinearLayout
            android:id="@+id/btn_help"
            android:layout_width="150dp"
            android:layout_height="60dp"
            android:layout_alignParentTop="true"
            android:layout_centerHorizontal="true"
            android:background="@drawable/btn_normal_condition"
            android:clickable="true"
            android:elevation="4dp"
            android:focusable="true"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            app:layout_constraintBottom_toBottomOf="@+id/Border"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/helpTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/shantell_sans_bold"
                android:gravity="center"
                android:text="Need a Help? 3/3"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:orientation="vertical"
            android:gravity="bottom"
            app:layout_constraintTop_toBottomOf="@+id/Border"
            app:layout_constraintBottom_toBottomOf="parent">

            <RelativeLayout
                android:id="@+id/drawing_container"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/drawing_area_bg">

                <com.happym.mathsquare.Animation.DrawingView
                    android:id="@+id/drawing_view"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <ImageView
                    android:id="@+id/btn_clear"
                    android:layout_width="@dimen/clear_btn_size"
                    android:layout_height="@dimen/clear_btn_size"
                    android:layout_alignParentStart="true"
                    android:layout_alignParentTop="true"
                    android:layout_margin="18dp"
                    android:background="@drawable/bg_clear_circle"
                    android:clickable="true"
                    android:elevation="6dp"
                    android:focusable="true"
                    android:padding="5dp"
                    android:src="@drawable/ic_clear" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentTop="true"
                    android:layout_centerHorizontal="true"
                    android:layout_marginTop="16dp"
                    android:letterSpacing="0.1"
                    android:text="DRAW YOUR ANSWER HERE"
                    android:textColor="#9E9E9E"
                    android:textSize="@dimen/draw_label_text_size" />

                <TextView
                    android:id="@+id/hint_question_mark"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:fontFamily="@font/shantell_sans_bold"
                    android:text="?"
                    android:textColor="#E0E0E0"
                    android:textSize="@dimen/hint_question_mark_size" />

            </RelativeLayout>
        </LinearLayout>


        <LinearLayout
            android:layout_height="55dp"
            android:layout_width="455dp"
            android:gravity="center_vertical"
            app:layout_constraintTop_toTopOf="parent"
            android:orientation="horizontal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="20dp"
            android:id="@+id/linearLayout2">

            <LinearLayout
                android:layout_height="match_parent"
                android:layout_width="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="30dp">

                <ImageButton
                    android:layout_height="55dp"
                    android:layout_width="55dp"
                    android:background="@drawable/circle_box"
                    android:layout_marginLeft="25dp"
                    app:srcCompat="@drawable/ic_home"
                    android:id="@+id/imgBtn_home" />

            </LinearLayout>

            <TextView
                android:layout_height="55dp"
                android:layout_width="wrap_content"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:shadowRadius="2"
                android:fontFamily="@font/paytone_one"
                android:shadowColor="#000000"
                android:shadowDx="4"
                android:shadowDy="3"
                android:layout_weight="1"
                android:id="@+id/text_operation"
                android:text="Subtraction" />

            <LinearLayout
                android:layout_height="match_parent"
                android:layout_width="wrap_content"
                android:layout_marginEnd="30dp"
                android:gravity="end"
                android:orientation="horizontal">

                <ImageButton
                    android:layout_height="55dp"
                    android:layout_width="55dp"
                    android:background="@drawable/circle_box"
                    android:layout_marginRight="25dp"
                    app:srcCompat="@drawable/ic_pause"
                    android:id="@+id/imgBtn_pause" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_height="55dp"
            android:layout_width="match_parent"
            android:gravity="center_vertical"
            app:layout_constraintTop_toTopOf="parent"
            android:orientation="horizontal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="120dp"
            android:id="@+id/heartWithTimer">

            <LinearLayout
                android:layout_height="match_parent"
                android:layout_width="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="36dp">

                <FrameLayout
                    android:layout_height="40dp"
                    android:layout_width="96dp"
                    android:gravity="center"
                    android:id="@+id/heart_choice">

                    <LinearLayout
                        android:layout_height="match_parent"
                        android:layout_width="match_parent"
                        android:background="@drawable/btn_boxsmall"
                        android:gravity="center|start"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:gravity="center|start"
                            android:orientation="horizontal"
                            android:layout_marginStart="12dp">

                            <ImageView
                                android:layout_height="35dp"
                                android:layout_width="35dp"
                                android:scaleType="centerCrop"
                                android:src="@drawable/ic_heart"
                                android:padding="2dp"
                                android:id="@+id/icon_heart"
                                android:layout_gravity="center" />

                            <TextView
                                android:layout_height="wrap_content"
                                android:layout_width="wrap_content"
                                android:textSize="23sp"
                                android:textColor="@color/white"
                                android:layout_marginStart="8dp"
                                android:layout_marginBottom="4dp"
                                android:gravity="center_horizontal"
                                android:shadowRadius="4"
                                android:fontFamily="@font/paytone_one"
                                android:shadowColor="#000000"
                                android:shadowDx="2"
                                android:shadowDy="2"
                                android:id="@+id/heart_txt"
                                android:text="3"
                                android:paddingTop="2dp" />

                        </LinearLayout>

                    </LinearLayout>

                </FrameLayout>

            </LinearLayout>

            <TextView
                android:layout_height="55dp"
                android:layout_width="wrap_content"
                android:textSize="23sp"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:shadowRadius="2"
                android:fontFamily="@font/paytone_one"
                android:paddingBottom="12dp"
                android:shadowColor="#000000"
                android:shadowDx="4"
                android:shadowDy="3"
                android:layout_weight="1"
                android:id="@+id/text_question_progress"
                android:text="4/10" />

            <LinearLayout
                android:layout_height="match_parent"
                android:layout_width="wrap_content"
                android:layout_marginEnd="36dp"
                android:gravity="end"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_height="40dp"
                    android:layout_width="96dp"
                    android:gravity="center"
                    android:id="@+id/timer_choice">

                    <LinearLayout
                        android:layout_height="match_parent"
                        android:layout_width="match_parent"
                        android:background="@drawable/btn_boxsmall"
                        android:gravity="center|start"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:gravity="center|start"
                            android:orientation="horizontal"
                            android:layout_marginStart="10dp">

                            <ImageView
                                android:layout_height="35dp"
                                android:layout_width="35dp"
                                android:scaleType="centerCrop"
                                android:src="@drawable/ic_clock"
                                android:padding="2dp"
                                android:id="@+id/icon_timer"
                                android:layout_gravity="center" />

                            <TextView
                                android:layout_height="wrap_content"
                                android:layout_width="wrap_content"
                                android:textSize="16sp"
                                android:textColor="@color/white"
                                android:layout_marginStart="2dp"
                                android:layout_marginBottom="4dp"
                                android:gravity="center_horizontal"
                                android:shadowRadius="4"
                                android:fontFamily="@font/paytone_one"
                                android:shadowColor="#000000"
                                android:shadowDx="2"
                                android:shadowDy="2"
                                android:id="@+id/timer_txt"
                                android:text="10:00"
                                android:paddingTop="4dp" />

                        </LinearLayout>

                    </LinearLayout>

                </FrameLayout>

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/linearLayout6"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="@+id/Border"
            app:layout_constraintEnd_toEndOf="@+id/Border"
            app:layout_constraintHorizontal_bias="0.50"
            app:layout_constraintStart_toStartOf="@+id/Border"
            app:layout_constraintTop_toTopOf="@+id/Border"
            app:layout_constraintVertical_bias="0.660">

            <!-- Horizontal row for number1 operator number2 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical|end">

                <TextView
                    android:id="@+id/text_givenone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/shantell_sans_bold"
                    android:gravity="center"
                    android:text="55"
                    android:textColor="#FFFFFF"
                    android:textSize="40sp"
                    android:paddingEnd="8dp"/>

                <TextView
                    android:id="@+id/text_operator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/shantell_sans_bold"
                    android:gravity="center"
                    android:text="+"
                    android:textColor="#FFFFFF"
                    android:textSize="40sp"
                    android:paddingEnd="8dp"/>

                <TextView
                    android:id="@+id/text_giventwo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/shantell_sans_bold"
                    android:gravity="center"
                    android:text="999"
                    android:textColor="#FFFFFF"
                    android:textSize="40sp"/>
            </LinearLayout>

        </LinearLayout>


        <TextView
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"
            android:visibility="invisible"
            app:layout_constraintHorizontal_bias="0.498"
            android:textSize="17sp"
            android:textColor="@color/white"
            android:layout_marginTop="20dp"
            android:shadowRadius="2"
            app:layout_constraintStart_toStartOf="parent"
            android:fontFamily="@font/paytone_one"
            android:shadowColor="#000000"
            app:layout_constraintEnd_toEndOf="parent"
            android:shadowDx="4"
            android:shadowDy="3"
            android:id="@+id/text_feedback"
            android:text="" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <RelativeLayout
        android:id="@+id/dialogOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#B0000000"
        android:gravity="center"
        android:visibility="gone">

        <!-- ═══════════════════════════════════════ -->
        <!--           SUCCESS DIALOG CARD          -->
        <!-- ═══════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/customDialogSuccess"
            android:layout_width="584dp"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:background="@drawable/dialog_success_game_bg"
            android:elevation="16dp"
            android:gravity="center"
            android:visibility="gone"
            android:orientation="vertical"
            android:padding="28dp">

            <!-- Star burst / top badge strip -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/badge_correct_bg"
                android:text="✓  CORRECT!"
                android:fontFamily="@font/paytone_one"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:letterSpacing="0.15"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:layout_marginBottom="14dp" />

            <!-- Icon -->
            <ImageView
                android:id="@+id/dialogIcon"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:layout_marginBottom="12dp"
                android:src="@drawable/ic_happy" />

            <!-- Title -->
            <TextView
                android:id="@+id/dialogTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:gravity="center"
                android:text="Amazing Job!"
                android:fontFamily="@font/shantell_sans_bold"
                android:textStyle="bold"
                android:textColor="@color/gameBrown"
                android:shadowColor="#FFFFFF"
                android:shadowDx="0"
                android:shadowDy="3"
                android:shadowRadius="0"
                android:textAlignment="center"
                android:textSize="36sp"/>

            <!-- Divider line (gold) -->
            <View
                android:layout_width="180dp"
                android:layout_height="3dp"
                android:background="@color/gameGold"
                android:layout_marginBottom="12dp"/>

            <!-- Points earned -->
            <TextView
                android:id="@+id/pointsEarnedTxt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+10 Points!"
                android:fontFamily="@font/paytone_one"
                android:textColor="@color/gameGold"
                android:textSize="32sp"
                android:shadowColor="#7A5900"
                android:shadowDx="2"
                android:shadowDy="3"
                android:shadowRadius="0"
                android:layout_marginBottom="6dp"/>

            <!-- Bonus label -->
            <TextView
                android:id="@+id/bonusTxt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:background="@drawable/badge_bonus_bg"
                android:text="⚡ Quick Thinker Bonus!"
                android:fontFamily="@font/shantell_sans_bold"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:layout_marginBottom="12dp"/>

            <!-- Message -->
            <TextView
                android:id="@+id/dialogMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:lineSpacingExtra="6dp"
                android:text="You got it right!\nReady for the next challenge?"
                android:fontFamily="@font/shantell_sans_bold"
                android:textColor="@color/gameShadowBrown"
                android:shadowColor="#FFFFFF"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="2"
                android:textAlignment="center"
                android:textSize="20sp"/>

        </LinearLayout>

        <!-- ═══════════════════════════════════════ -->
        <!--            FAILED DIALOG CARD          -->
        <!-- ═══════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/customDialogFailed"
            android:layout_width="584dp"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:background="@drawable/dialog_failed_game_bg"
            android:elevation="16dp"
            android:gravity="center"
            android:visibility="gone"
            android:orientation="vertical"
            android:padding="28dp">

            <!-- Top strip -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/badge_wrong_bg"
                android:text="✗  INCORRECT"
                android:fontFamily="@font/paytone_one"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:letterSpacing="0.15"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:layout_marginBottom="14dp" />

            <!-- Icon -->
            <ImageView
                android:id="@+id/dialogIconFailed"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:layout_marginBottom="12dp"
                android:src="@drawable/ic_error_sad_face" />

            <!-- Title -->
            <TextView
                android:id="@+id/dialogTitleFailed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:gravity="center"
                android:text="Oops! Incorrect"
                android:fontFamily="@font/shantell_sans_bold"
                android:textStyle="bold"
                android:textColor="@color/gameRed"
                android:shadowColor="#FFFFFF"
                android:shadowDx="0"
                android:shadowDy="3"
                android:shadowRadius="0"
                android:textAlignment="center"
                android:textSize="36sp"/>

            <!-- Divider -->
            <View
                android:layout_width="180dp"
                android:layout_height="3dp"
                android:background="@color/gameRed"
                android:layout_marginBottom="12dp"/>

            <!-- Message -->
            <TextView
                android:id="@+id/dialogMessageFailed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Don't give up! Try again!"
                android:textSize="20sp"
                android:textColor="@color/gameShadowBrown"
                android:gravity="center"
                android:fontFamily="@font/shantell_sans_bold"
                android:shadowColor="#FFFFFF"
                android:shadowDx="1"
                android:shadowDy="2"
                android:shadowRadius="2"
                android:layout_marginBottom="14dp"/>

            <!-- Visual flexbox container -->
            <com.google.android.flexbox.FlexboxLayout
                android:id="@+id/visualContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/visual_container_bg"
                android:padding="12dp"
                app:flexWrap="wrap"
                app:justifyContent="center"
                app:alignItems="center"/>

            <!-- Bottom decoration -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp"
                android:gravity="center">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="💡" android:textSize="22sp" android:layout_marginEnd="6dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Keep Thinking!" android:textSize="15sp"
                    android:fontFamily="@font/shantell_sans_bold"
                    android:textColor="@color/gameShadowBrown"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="💡" android:textSize="22sp" android:layout_marginStart="6dp"/>
            </LinearLayout>

        </LinearLayout>

    </RelativeLayout>

</FrameLayout>