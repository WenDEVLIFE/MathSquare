<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.MathSquare" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/black</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="colorOnSurface">@color/black</item>
        <item name="colorSurface">@color/white</item>

        <item name="android:statusBarColor">
            #00FFFFFF
        </item>
        <item name="android:navigationBarColor">
            #00FFFFFF
        </item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.MathSquare" parent="Base.Theme.MathSquare" />

    <style name="FullScreenDialog" parent="Theme.AppCompat.Light.Dialog">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>

    <style name="RoundedAlertDialog" parent="ThemeOverlay.AppCompat.Dialog">
        <item name="android:background">@drawable/dialog_background</item>
        <item name="android:windowMinWidthMajor">80%</item>
        <item name="android:windowMinWidthMinor">80%</item>
    </style>

    <style name="DialogTextStyle">
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:shadowRadius">2</item>
        <item name="android:shadowColor">#000000</item>
        <item name="android:shadowDx">4</item>
        <item name="android:shadowDy">3</item>
        <item name="android:fontFamily">@font/shantell_sans_bold</item>
    </style>

    <style name="KidFriendlyDialog" parent="Theme.MaterialComponents.Light.Dialog.Alert">
        <item name="android:windowBackground">@drawable/dialog_inset_background</item>
        <item name="colorSurface">#FFFDE7</item>
        <item name="materialThemeOverlay">@style/KidFriendlyDialog_Overlay</item>
    </style>

    <style name="KidFriendlyDialog_Success" parent="KidFriendlyDialog">
        <item name="android:windowTitleStyle">@style/DialogTitleText.Success</item>
    </style>

    <style name="KidFriendlyDialog_Overlay">
        <item name="android:gravity">center</item>
        <item name="android:textAlignment">center</item>
    </style>

    <style name="ShapeAppearanceOverlay.MyApp.Dialog.Rounded" parent="">
        <item name="cornerSize">30dp</item>
    </style>

    <style name="DialogTitleText" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#FF4081</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="DialogTitleText.Success" parent="DialogTitleText">
        <item name="android:textColor">#4CAF50</item> </style>

</resources>
